# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Required: Open WebUI API key (Settings -> Account -> API Keys)
OPENWEBUI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: base URL of your Open WebUI instance. Defaults to http://localhost:3000
OPENWEBUI_BASE_URL=http://localhost:3000

# Optional: default model to use. Leave empty to use your Open WebUI default.
# Examples: gpt-4o, llama3.1:8b, gemini-1.5-pro
DEFAULT_MODEL=

# Strongly recommended: comma-separated Telegram user IDs allowed to use the bot.
# Find yours by messaging @userinfobot on Telegram.
ALLOWED_USER_IDS=123456789

# Optional: HTTP request timeout in seconds (default: 120)
REQUEST_TIMEOUT=120

# Optional: log level (DEBUG, INFO, WARNING, ERROR). Default: INFO
LOG_LEVEL=INFO