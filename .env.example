# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Open WebUI API key (Settings -> Account -> API Keys)
OPENWEBUI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx


# ---------------------------------------------------------------------------
# Model resolution
# ---------------------------------------------------------------------------

# Optional: explicit default model. If empty, the bot falls back to:
#   1. The user's OWUI default (from /api/v1/users/user.settings.ui.models[0])
#   2. The first model returned by /api/models
# Examples: gpt-4o, llama3.1:8b, ai21/jamba-large-1.7
DEFAULT_MODEL=

# Optional: per-chat system prompt applied to all Telegram messages.
# Leave empty to use the model's OWUI-default system prompt.
# Can be overridden per-chat with /system <prompt> in Telegram.
DEFAULT_SYSTEM_PROMPT=


# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------

# Base URL of your Open WebUI instance.
# Same-host Docker:    http://host.docker.internal:3000
# Sibling container:   http://open-webui:8080
# Remote server:       https://openwebui.your-domain.com
# Bare metal both:     http://localhost:3000
OPENWEBUI_BASE_URL=http://localhost:3000


# ---------------------------------------------------------------------------
# Telegram user allowlist (STRONGLY recommended)
# ---------------------------------------------------------------------------

# Comma-separated Telegram numeric user IDs allowed to use the bot.
# Get yours by messaging @userinfobot on Telegram.
ALLOWED_USER_IDS=123456789


# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# HTTP request timeout for Open WebUI API calls, in seconds (default: 120)
REQUEST_TIMEOUT=120

# Path to the persistent sessions file (default: /app/data/sessions.json)
# Mapped to ./data/sessions.json in docker-compose.yml so sessions survive restarts
SESSIONS_FILE=/app/data/sessions.json

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Throttle for streaming message edits, in seconds (default: 1.0)
# Lower = more responsive, more Telegram API calls
STREAM_THROTTLE_SECONDS=1.0


# ---------------------------------------------------------------------------
# Webhook mode (optional — leave WEBHOOK_URL empty to use polling)
# ---------------------------------------------------------------------------

# When set, the bot switches from long-polling to webhook mode.
# Example: https://telegram-bridge.your-domain.com
WEBHOOK_URL=
WEBHOOK_PORT=8089
WEBHOOK_LISTEN=0.0.0.0


# ---------------------------------------------------------------------------
# Health endpoint
# ---------------------------------------------------------------------------

# HTTP port for the /health endpoint (default: 8088)
HEALTH_PORT=8088


# ---------------------------------------------------------------------------
# Outbound API (/api/outbound) — receives messages from the OWUI tool
# ---------------------------------------------------------------------------

# Port the outbound API listens on (default: 8089).
# The OWUI send_telegram tool POSTs here instead of directly to Telegram.
OUTBOUND_PORT=8089

# Bind address for the outbound API. Default 127.0.0.1 = only the bridge
# container can reach it. Change to 0.0.0.0 ONLY if Open WebUI runs on a
# different host and you understand the security implications.
OUTBOUND_LISTEN=127.0.0.1

# Optional: shared bearer token. When set, the OWUI tool must send
# Authorization: Bearer <token> on every /api/outbound call.
# When empty (default), the API relies entirely on the bind address for access
# control — fine for same-host deployments, do not expose the port externally.
BRIDGE_OUTBOUND_TOKEN=